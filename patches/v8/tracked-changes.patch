+
+// Report a bulk-memory region to WebTSan, sampled to bound cost. Only fires
+// when wasm_tsan is enabled and the memory is shared. Records up to 64 evenly
+// spaced single-byte accesses across [offset, offset+size).
+inline void MaybeReportTSanBulkRange(
+    Tagged<WasmTrustedInstanceData> trusted_data, uint32_t mem_index,
+    uintptr_t offset, uintptr_t size, bool is_write) {
+  if (V8_LIKELY(!v8_flags.wasm_tsan)) return;
+  if (size == 0) return;
+  auto& cb = v8::internal::web_tsan::g_callbacks;
+  if (!cb.record_range || !cb.get_current_tid) return;
+  auto memory_object = trusted_data->memory_object(mem_index);
+  auto backing = memory_object->backing_store();
+  if (!backing || !backing->is_shared()) return;
+  void* bs = backing->buffer_start();
+  size_t byte_length = backing->byte_length();
+  uint32_t tid = cb.get_current_tid();
+  if (tid == UINT32_MAX) return;
+  constexpr uintptr_t kMaxSamples = 64;
+  uintptr_t n = size < kMaxSamples ? size : kMaxSamples;
+  uintptr_t stride = size / n;
+  if (stride == 0) stride = 1;
+  for (uintptr_t i = 0; i < n; ++i) {
+    uintptr_t o = offset + i * stride;
+    if (o >= offset + size) break;
+    cb.record_range(bs, byte_length, o, 1, tid, is_write ? 1 : 0);
+  }
+}
